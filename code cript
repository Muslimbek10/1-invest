def run_step1(df: pd.DataFrame, log) -> list[pd.DataFrame]:
    pieces = []
    for i, block in enumerate(STEP1_BLOCKS, start=1):
        sub = df[df["g1"].isin(block["filter_values"])].copy()
        if sub.empty:
            pieces.append(pd.DataFrame(columns=FINAL_COLS_A))
            log(f"  step1 #{i:>2}: ns={block['target_ns']} rows=0")
            continue

        grouped = sub.groupby(
            ["okpo", "section", block["soato_col"], "g1"], as_index=False
        )["g12"].sum()
        grouped = grouped.rename(columns={
            "section": "razdel",
            block["soato_col"]: "SOATO",
            "g1": "ns",
            "g12": "g1",
        })
        grouped["ns"] = block["target_ns"]
        grouped["ns_name"] = np.nan
        grouped["tur"] = "1-invest"
        out = pad_and_order_a(grouped)
        log(f"  step1 #{i:>2}: ns={block['target_ns']} rows={len(out):,}")
        pieces.append(out)
    return pieces


