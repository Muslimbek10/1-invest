def aggregate_and_finalize(df: pd.DataFrame) -> pd.DataFrame:
    df["condition"] = pd.to_numeric(df["condition"], errors="coerce")
    for c in ["g1", "g2", "g3", "g4", "g5", "g6", "g8"]:
        df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0)

    mask_main = ~df["condition"].isin([311, 321, 331, 332])
    agg_main = (df.loc[mask_main]
                  .groupby(GROUP_KEYS_B, dropna=False, as_index=False)
                  .agg({"g1": "sum", "g2": "sum", "g4": "sum", "g5": "sum", "g8": "sum"}))

    mask_36 = df["condition"].isin([31, 32, 33])
    agg_36 = (df.loc[mask_36]
                .groupby(GROUP_KEYS_B, dropna=False, as_index=False)
                .agg({"g3": "sum", "g6": "sum"}))

    result = agg_main.merge(agg_36, on=GROUP_KEYS_B, how="left")
    result["g3"] = result["g3"].fillna(0)
    result["g6"] = result["g6"].fillna(0)
    result.loc[result["razdel"] == 3, "razdel"] = 1
    result["g7"] = result["g1"] - result["g2"] - result["g6"]
    return result[FINAL_COLS_B]




def apply_katalog_g7(df: pd.DataFrame, katalog_path: Path) -> pd.DataFrame:

    sec = pd.read_excel(katalog_path)

    df["inn"] = df["inn"].astype(str)

    df["okpo"] = df["okpo"].astype(str)

    sec["INN"] = sec["INN"].astype(str)

    sec["OKPO"] = sec["OKPO"].astype(str)

    df = df.merge(sec, left_on=["inn", "okpo"], right_on=["INN", "OKPO"], how="left")

    for col in ["2_xona", "4_xona", "5_xona"]:

        if col in df.columns:

            df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

        else:

            df[col] = 0

    # Fallback: 2_xona -> 4_xona -> 5_xona

    df["g7"] = np.where(

        df["2_xona"] != 0, df["2_xona"],

        np.where(df["4_xona"] != 0, df["4_xona"], df["5_xona"])

    )

    df["g7"] = pd.to_numeric(df["g7"], errors="coerce").fillna(0)

    return df


def build_intermediate(df: pd.DataFrame) -> pd.DataFrame:
    df["davr"] = 12
    df["npah"] = 1000
    df["EdIzm"] = ""
    df["akt"] = ""
    df["razdel"] = df["section"]
    df["ns_name"] = df["g3"]
    df["SOATO"] = df["g9"]
    df["country"] = df["g5"]
    df["OKED"] = df["g7"]
    df["ns"] = df["g4"]
    df["ns1"] = df["g10"]
    df["condition"] = df["g2"]
    df["kurs"] = df["g11"]
    df["ehud"] = df["soato"].astype(str).str[:4]

    for c in ["g11", "g12", "g13", "g14", "g15", "g18"]:
        df[c] = pd.to_numeric(df[c], errors="coerce")

    df["new_g1"]  = df["g12"]
    df["new_g2"]  = df["g13"]
    df["new_g3"]  = df["g13"]
    df["new_g4"]  = df["g14"]
    df["new_g5"]  = df["g15"]
    df["new_g6"]  = df["g12"].fillna(0) - df["g13"].fillna(0)
    df["new_g7"]  = ""
    df["new_g8"]  = df["g18"]
    df["new_g9"]  = ""
    df["new_g10"] = ""

    inter = [
        "davr", "inn", "okpo", "razdel", "ns_name", "SOATO", "country", "OKED",
        "ns", "ns1", "EdIzm", "npah", "akt",
        "new_g1", "new_g2", "new_g3", "new_g4", "new_g5",
        "new_g6", "new_g7", "new_g8", "new_g9", "new_g10",
        "kurs", "ehud", "tur", "condition",
    ]
    df = df[inter].copy()
    df = df.rename(columns={f"new_g{i}": f"g{i}" for i in range(1, 11)})
    return df


def run_fx_b(path_csv: Path, path_kat: Path, log) -> pd.DataFrame:
    log("[B/fx] reading...")
    df = read_csv_safe(path_csv)
    df["section"] = pd.to_numeric(df["section"], errors="coerce")
    df = df[df["section"] == 26].copy()
    df["tur"] = "1-fx"
    df = df[["inn", "soato", "okpo", "section",
             "g1", "g2", "g3", "g4", "g5", "g6", "g7", "g8", "g9", "g10", "tur"]].copy()
    orig = df.copy()
    df["g2"], df["g3"] = df["g3"], df["g2"]
    df["g6"] = 0; df["g7"] = 0; df["g8"] = 0
    df["g9"] = df["soato"].astype(str).str[:7]
    df["g10"] = orig["g6"]; df["g11"] = orig["g7"]
    df["g12"] = orig["g8"]; df["g13"] = orig["g9"]; df["g14"] = orig["g10"]
    df = apply_katalog_g7(df, path_kat)
    df.loc[df["section"] == 26, "section"] = 3
    df["g15"] = ""; df["g16"] = ""; df["g17"] = ""; df["g18"] = ""
    df = build_intermediate(df)
    result = aggregate_and_finalize(df)
    log(f"  B/fx rows: {len(result):,}")
    return result


def run_nnt_b(path_csv: Path, path_kat: Path, log) -> pd.DataFrame:
    log("[B/nnt] reading...")
    df = read_csv_safe(path_csv)
    df["section"] = pd.to_numeric(df["section"], errors="coerce")
    df = df[df["section"] == 8].copy()
    df["tur"] = "1-nnt"
    df = df[["inn", "soato", "okpo", "section",
             "g1", "g2", "g3", "g4", "g5", "g6", "g7", "g8", "g9", "g10", "tur"]].copy()
    orig = df.copy()
    df["g2"], df["g3"] = df["g3"], df["g2"]
    df["g6"] = 0; df["g7"] = 0; df["g8"] = 0
    df["g9"] = df["soato"].astype(str).str[:7]
    df["g10"] = orig["g6"]; df["g11"] = orig["g7"]
    df["g12"] = orig["g8"]; df["g13"] = orig["g9"]; df["g14"] = orig["g10"]
    df = apply_katalog_g7(df, path_kat)
    df.loc[df["section"] == 8, "section"] = 3
    df["g15"] = ""; df["g16"] = ""; df["g17"] = ""; df["g18"] = ""
    df = build_intermediate(df)
    result = aggregate_and_finalize(df)
    log(f"  B/nnt rows: {len(result):,}")
    return result


def run_notijorat_b(path_csv: Path, log) -> pd.DataFrame:
    log("[B/notijorat] reading...")
    df = read_csv_safe(path_csv)
    df["section"] = pd.to_numeric(df["section"], errors="coerce")
    df["g4"] = pd.to_numeric(df["g4"], errors="coerce")
    df = df[df["section"] == 7].copy()
    df["tur"] = "1-notijorat"
    df.loc[df["section"] == 7, "section"] = 3
    df["g4"] = df["g4"].replace({10: 11, 11: 13})
    df = df[["inn", "soato", "okpo", "section",
             "g1", "g2", "g3", "g4", "g5", "g6", "g7", "g8", "g9", "g10",
             "g11", "g12", "g13", "g14", "tur"]].copy()
    df["g15"] = ""; df["g16"] = ""; df["g17"] = ""; df["g18"] = ""
    df = build_intermediate(df)
    result = aggregate_and_finalize(df)
    log(f"  B/notijorat rows: {len(result):,}")
    return result


def run_invest_b(path_csv: Path, log) -> pd.DataFrame:
    log("[B/invest] reading...")
    df = read_csv_safe(path_csv)
    df["section"] = pd.to_numeric(df["section"], errors="coerce")
    df = df[df["section"] == 3].copy()
    df["tur"] = "1-invest"
    df = df[["inn", "soato", "okpo", "section",
             "g1", "g2", "g3", "g4", "g5", "g6", "g7", "g8", "g9", "g10",
             "g11", "g12", "g13", "g14", "g15", "g16", "g17", "g18", "tur"]].copy()
    df = build_intermediate(df)
    result = aggregate_and_finalize(df)

    def _clean_kurs(x):
        if pd.isna(x):
            return x
        return int(x) if float(x).is_integer() else float(x)

    result["kurs"] = pd.to_numeric(result["kurs"], errors="coerce").map(_clean_kurs)
    log(f"  B/invest rows: {len(result):,}")
    return result


def run_pipeline_b(paths: dict, log) -> pd.DataFrame:
    log("\n=== Pipeline B (4-step) ===")
    fx_df    = run_fx_b(paths["fx"], paths["fx_katalog"], log)
    nnt_df   = run_nnt_b(paths["nnt"], paths["nnt_katalog"], log)
    noti_df  = run_notijorat_b(paths["notijorat"], log)
    inv_df   = run_invest_b(paths["invest"], log)
    combined = pd.concat([fx_df, nnt_df, noti_df, inv_df], axis=0, ignore_index=True)
    combined = combined[FINAL_COLS_B]
    log(f"Pipeline B: {len(combined):,} rows")
    return combined


