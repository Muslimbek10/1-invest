class App(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Yillik Hisobot")
        self.geometry("900x720")
        self.minsize(720, 560)
        self.configure(fg_color=BG_MAIN)

        # Layout grid: header / files card / output card / log / footer
        self.grid_columnconfigure(0, weight=1)
        self.grid_rowconfigure(3, weight=1)

        self._build_header()
        self._build_files_card()
        self._build_output_card()
        self._build_log_area()
        self._build_footer()

        self.path_vars: dict[str, ctk.StringVar] = {}
        self._populate_file_rows()
        self._auto_detect_in_cwd()

    # ---------- header ----------
    def _build_header(self):
        bar = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                           border_width=1, border_color=BORDER, height=70)
        bar.grid(row=0, column=0, padx=16, pady=(16, 8), sticky="ew")
        bar.grid_propagate(False)
        bar.grid_columnconfigure(0, weight=1)
        ctk.CTkLabel(bar, text="Yillik 1700 — Combiner",
                     text_color=TEXT_DARK,
                     font=ctk.CTkFont(size=20, weight="bold")
                     ).grid(row=0, column=0, padx=20, pady=(14, 0), sticky="w")
        ctk.CTkLabel(bar,
                     text="Pick all input files, then run. One Excel file is produced.",
                     text_color=TEXT_MUTED,
                     font=ctk.CTkFont(size=12)
                     ).grid(row=1, column=0, padx=20, pady=(2, 12), sticky="w")

    # ---------- files card ----------
    def _build_files_card(self):
        card = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                            border_width=1, border_color=BORDER)
        card.grid(row=1, column=0, padx=16, pady=8, sticky="ew")
        card.grid_columnconfigure(0, weight=1)
        ctk.CTkLabel(card, text="Input files",
                     text_color=TEXT_DARK,
                     font=ctk.CTkFont(size=14, weight="bold")
                     ).grid(row=0, column=0, padx=16, pady=(12, 6), sticky="w")
        self.files_inner = ctk.CTkFrame(card, fg_color=BG_CARD)
        self.files_inner.grid(row=1, column=0, padx=10, pady=(0, 12), sticky="ew")
        self.files_inner.grid_columnconfigure(1, weight=1)

    def _populate_file_rows(self):
        for i, (key, label, ext) in enumerate(FILE_FIELDS):
            ctk.CTkLabel(self.files_inner, text=label,
                         text_color=TEXT_DARK, anchor="w", width=200,
                         font=ctk.CTkFont(size=12)
                         ).grid(row=i, column=0, padx=(8, 6), pady=4, sticky="w")
            var = ctk.StringVar(value="")
            self.path_vars[key] = var
            entry = ctk.CTkEntry(self.files_inner, textvariable=var,
                                 fg_color="#FFFFFF", text_color=TEXT_DARK,
                                 border_color=BORDER, border_width=1, height=30)
            entry.grid(row=i, column=1, padx=6, pady=4, sticky="ew")
            ctk.CTkButton(self.files_inner, text="Browse",
                          width=80, height=30,
                          fg_color=ACCENT, hover_color=ACCENT_HOVER,
                          text_color="#FFFFFF",
                          command=lambda k=key, e=ext: self._browse(k, e)
                          ).grid(row=i, column=2, padx=(6, 8), pady=4)

    def _browse(self, key: str, ext: str):
        if ext == "csv":
            ftypes = [("CSV files", "*.csv"), ("All files", "*.*")]
        else:
            ftypes = [("Excel files", "*.xlsx *.xls"), ("All files", "*.*")]
        path = filedialog.askopenfilename(title=f"Select {key}", filetypes=ftypes)
        if path:
            self.path_vars[key].set(path)

    def _auto_detect_in_cwd(self):
        """Auto-fill any default-named file that's already in cwd."""
        cwd = Path.cwd()
        for key, name in DEFAULT_NAMES.items():
            p = cwd / name
            if p.exists():
                self.path_vars[key].set(str(p))

    # ---------- output card ----------
    def _build_output_card(self):
        card = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                            border_width=1, border_color=BORDER)
        card.grid(row=2, column=0, padx=16, pady=8, sticky="ew")
        card.grid_columnconfigure(1, weight=1)
        ctk.CTkLabel(card, text="Output file",
                     text_color=TEXT_DARK,
                     font=ctk.CTkFont(size=14, weight="bold")
                     ).grid(row=0, column=0, columnspan=3,
                            padx=16, pady=(12, 6), sticky="w")
        ctk.CTkLabel(card, text="Save as", text_color=TEXT_DARK, width=80,
                     font=ctk.CTkFont(size=12)
                     ).grid(row=1, column=0, padx=(16, 6), pady=(0, 12), sticky="w")
        self.output_var = ctk.StringVar(value=str(Path.cwd() / "all_combined_final.xlsx"))
        ctk.CTkEntry(card, textvariable=self.output_var,
                     fg_color="#FFFFFF", text_color=TEXT_DARK,
                     border_color=BORDER, border_width=1, height=30
                     ).grid(row=1, column=1, padx=6, pady=(0, 12), sticky="ew")
        ctk.CTkButton(card, text="Browse", width=80, height=30,
                      fg_color=ACCENT, hover_color=ACCENT_HOVER,
                      text_color="#FFFFFF", command=self._browse_output
                      ).grid(row=1, column=2, padx=(6, 16), pady=(0, 12))

    def _browse_output(self):
        path = filedialog.asksaveasfilename(
            title="Save combined file as",
            defaultextension=".xlsx",
            filetypes=[("Excel files", "*.xlsx")],
            initialfile="all_combined_final.xlsx",
        )
        if path:
            self.output_var.set(path)

    # ---------- log ----------
    def _build_log_area(self):
        card = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                            border_width=1, border_color=BORDER)
        card.grid(row=3, column=0, padx=16, pady=8, sticky="nsew")
        card.grid_columnconfigure(0, weight=1)
        card.grid_rowconfigure(1, weight=1)
        ctk.CTkLabel(card, text="Log",
                     text_color=TEXT_DARK,
                     font=ctk.CTkFont(size=14, weight="bold")
                     ).grid(row=0, column=0, padx=16, pady=(12, 6), sticky="w")
        self.log_box = ctk.CTkTextbox(card, fg_color="#FAFAFA",
                                      text_color=TEXT_DARK,
                                      border_color=BORDER, border_width=1,
                                      font=ctk.CTkFont(family="Menlo", size=11))
        self.log_box.grid(row=1, column=0, padx=12, pady=(0, 12), sticky="nsew")
        self.log_box.configure(state="disabled")

    def _log(self, msg: str):
        self.log_box.configure(state="normal")
        self.log_box.insert("end", msg + "\n")
        self.log_box.see("end")
        self.log_box.configure(state="disabled")
        self.update_idletasks()

    # ---------- footer ----------
    def _build_footer(self):
        bar = ctk.CTkFrame(self, fg_color=BG_MAIN)
        bar.grid(row=4, column=0, padx=16, pady=(8, 16), sticky="ew")
        bar.grid_columnconfigure(0, weight=1)
        self.status_label = ctk.CTkLabel(bar, text="Ready.",
                                         text_color=TEXT_MUTED,
                                         font=ctk.CTkFont(size=12), anchor="w")
        self.status_label.grid(row=0, column=0, sticky="w", padx=4)
        self.run_btn = ctk.CTkButton(bar, text="Run & Combine",
                                     width=160, height=38,
                                     fg_color=ACCENT, hover_color=ACCENT_HOVER,
                                     text_color="#FFFFFF",
                                     font=ctk.CTkFont(size=13, weight="bold"),
                                     command=self._on_run)
        self.run_btn.grid(row=0, column=1, padx=4)

    def _set_status(self, text: str, color: str = TEXT_MUTED):
        self.status_label.configure(text=text, text_color=color)

    # ---------- run ----------
    def _on_run(self):
        # validate inputs
        missing = []
        paths: dict[str, Path] = {}
        for key, label, _ in FILE_FIELDS:
            raw = self.path_vars[key].get().strip()
            if not raw:
                missing.append(label)
                continue
            p = Path(raw)
            if not p.exists():
                missing.append(f"{label} (file not found)")
                continue
            paths[key] = p
        out = self.output_var.get().strip()
        if not out:
            missing.append("Output path")
        if missing:
            messagebox.showerror("Missing inputs", "Please fix:\n- " + "\n- ".join(missing))
            return
        out_path = Path(out)

        self.run_btn.configure(state="disabled")
        self._set_status("Running...", ACCENT)
        self.log_box.configure(state="normal")
        self.log_box.delete("1.0", "end")
        self.log_box.configure(state="disabled")

        threading.Thread(target=self._run_worker, args=(paths, out_path),
                         daemon=True).start()

    def _run_worker(self, paths: dict[str, Path], out_path: Path):
        try:
            df_a = run_pipeline_a(paths, self._log)
            df_b = run_pipeline_b(paths, self._log)
            self._log("\n=== Concatenating A + B ===")
            combined = combine_a_b(df_a, df_b)
            self._log(f"Combined rows: {len(combined):,}  cols: {len(combined.columns)}")

            self._log(f"\nWriting {out_path} ...")
            out_path.parent.mkdir(parents=True, exist_ok=True)
            with pd.ExcelWriter(out_path, engine="openpyxl") as xw:
                combined.to_excel(xw, sheet_name="all_combined", index=False)

            self._log("Done.")
            self.after(0, lambda: self._set_status(
                f"Saved {out_path.name}  ({len(combined):,} rows)", GREEN_OK))
            self.after(0, lambda: messagebox.showinfo(
                "Done", f"Combined file saved:\n{out_path}\n\nRows: {len(combined):,}"))
        except Exception as e:
            tb = traceback.format_exc()
            self._log("\nERROR:\n" + tb)
            self.after(0, lambda: self._set_status(f"Error: {e}", RED_ERR))
            self.after(0, lambda: messagebox.showerror("Error", str(e)))
        finally:
            self.after(0, lambda: self.run_btn.configure(state="normal"))


def main():
    app = App()
    app.mainloop()


if __name__ == "__main__":
