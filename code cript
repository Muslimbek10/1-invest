# ===========================================================================
def combine_a_b(a: pd.DataFrame, b: pd.DataFrame) -> pd.DataFrame:
    """
    Stack A and B vertically. The union of columns is FINAL_COLS_A
    (which is FINAL_COLS_B + 'ns_name'). B will get ns_name = None.
    """
    union_cols = FINAL_COLS_A  # has ns_name
    for col in union_cols:
        if col not in a.columns:
            a[col] = None
        if col not in b.columns:
            b[col] = None
    a = a[union_cols]
    b = b[union_cols]
    return pd.concat([a, b], axis=0, ignore_index=True)


