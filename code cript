def run_step2(df: pd.DataFrame, log) -> list[pd.DataFrame]:
    pieces = []
    for block in STEP2_BLOCKS:
        if block["g_col"] is None:
            sub = df.copy()
            keys = ["okpo", "section", "g3"]
        else:
            sub = df[df[block["g_col"]] == block["g_val"]].copy()
            keys = ["okpo", "section", block["g_col"], "g3"]

        if sub.empty:
            pieces.append(pd.DataFrame(columns=FINAL_COLS_A))
            log(f"  step2 {block['name']}: ns={block['ns']} rows=0")
            continue

        grouped = sub.groupby(keys, as_index=False).agg({"g6": "sum"})
        rename_map = {"section": "razdel", "g3": "SOATO", "g6": "g1"}
        if block["g_col"] is not None:
            rename_map[block["g_col"]] = "ns"
        result = grouped.rename(columns=rename_map)
        result["razdel"] = result["razdel"].replace({4: 3})
        result["ns"] = block["ns"]
        result["tur"] = "1-invest"
        out = pad_and_order_a(result)
        log(f"  step2 {block['name']}: ns={block['ns']} rows={len(out):,}")
        pieces.append(out)
    return pieces


