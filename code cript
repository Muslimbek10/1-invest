def read_csv_safe(path: Path) -> pd.DataFrame:
    """Read a semicolon-separated CSV, tolerating bad lines."""
    return pd.read_csv(
        path,
        sep=";",
        on_bad_lines="skip",
        encoding="utf-8",
        index_col=False,
        low_memory=False,
    )


def smart_numeric(series: pd.Series) -> pd.Series:
    """
    Coerce to numeric; per cell:
      NaN -> None, whole -> int, decimal -> float.
    """
    nums = pd.to_numeric(series, errors="coerce")

    def to_cell(x):
        if pd.isna(x):
            return None
        if float(x).is_integer():
            return int(x)
        return float(x)

    return pd.Series([to_cell(x) for x in nums], index=nums.index, dtype=object)


