def run_pipeline_a(paths: dict, log) -> pd.DataFrame:
    """Pipeline A: 7-step master that produces FINAL_COLS_A."""
    log("\n=== Pipeline A (7-step) ===")
    all_pieces: list[pd.DataFrame] = []

    # 1-invest (used by step1, step2, step4)
    log(f"[invest] reading {paths['invest'].name}")
    df_invest = read_csv_safe(paths["invest"])
    log(f"  raw rows: {len(df_invest):,}")
    for c in ["section", "g1", "g3", "g4", "g5", "g6", "g12", "g16", "g17"]:
        if c in df_invest.columns:
            df_invest[c] = pd.to_numeric(df_invest[c], errors="coerce")
    df_inv_s3 = df_invest[df_invest["section"] == 3].copy()
    df_inv_s4 = df_invest[df_invest["section"] == 4].copy()

    log("[step1] invest sec==3, sum g12")
    all_pieces.extend(run_step1(df_inv_s3, log))
    log("[step2] invest sec==4, sum g6")
    all_pieces.extend(run_step2(df_inv_s4, log))
    log("[step4] invest sec==3, g9-SOATO, var sum_col")
    all_pieces.extend(run_step4(df_inv_s3, log))

    # 1-korxona (step3)
    log(f"[korxona] reading {paths['korxona'].name}")
    df_kor = read_csv_safe(paths["korxona"])
    for c in ["section", "g1", "g3"]:
        if c in df_kor.columns:
            df_kor[c] = pd.to_numeric(df_kor[c], errors="coerce")
    df_kor = df_kor[
        ((df_kor["section"] == 5) & (df_kor["g1"].isin([114, 115]))) |
        ((df_kor["section"] == 9) & (df_kor["g1"].isin([181, 183, 184, 185, 186])))
    ].copy()
    log("[step3] korxona, sum g3")
    all_pieces.extend(run_step3(df_kor, log))

    # 1-notijorat (step5)
    log(f"[notijorat] reading {paths['notijorat'].name}")
    df_not = read_csv_safe(paths["notijorat"])
    for c in ["section", "g1", "g3"]:
        if c in df_not.columns:
            df_not[c] = pd.to_numeric(df_not[c], errors="coerce")
    df_not = df_not[(df_not["section"] == 8) &
                    (df_not["g1"].isin([401, 402, 403, 404, 405, 406]))].copy()
    log("[step5] notijorat, sum g3")
    all_pieces.extend(run_simple_blocks(df_not, STEP5_CONFIGS, "1-notijorat", "step5", log))

    # 1-nnt (step6)
    log(f"[nnt] reading {paths['nnt'].name}")
    df_nnt = read_csv_safe(paths["nnt"])
    for c in ["section", "g1", "g3"]:
        if c in df_nnt.columns:
            df_nnt[c] = pd.to_numeric(df_nnt[c], errors="coerce")
    df_nnt = df_nnt[
        ((df_nnt["section"] == 8) & (df_nnt["g1"] == 605)) |
        ((df_nnt["section"] == 9) & (df_nnt["g1"].isin([601, 602, 603, 604, 606])))
    ].copy()
    log("[step6] nnt, sum g3")
    all_pieces.extend(run_simple_blocks(df_nnt, STEP6_CONFIGS, "1-nnt", "step6", log))

    # 1-fx (step7)
    log(f"[fx] reading {paths['fx'].name}")
    df_fx = read_csv_safe(paths["fx"])
    for c in ["section", "g1", "g3"]:
        if c in df_fx.columns:
            df_fx[c] = pd.to_numeric(df_fx[c], errors="coerce")
    df_fx = df_fx[(df_fx["section"] == 27) &
                  (df_fx["g1"].isin([1601, 1602, 1603]))].copy()
    log("[step7] fx, sum g3")
    all_pieces.extend(run_simple_blocks(df_fx, STEP7_CONFIGS, "1-fx", "step7", log))

    final_a = pd.concat(all_pieces, ignore_index=True)
    final_a["g1"] = smart_numeric(final_a["g1"])
    log(f"Pipeline A: {len(final_a):,} rows")
    return final_a


