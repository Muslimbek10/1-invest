# ---- generic step5/6/7 runner ----
def run_simple_blocks(df, configs, tur, label, log) -> list[pd.DataFrame]:
    pieces = []
    for section, g1_val, out_razdel, out_ns in configs:
        sub = df[(df["section"] == section) & (df["g1"] == g1_val)].copy()
        if sub.empty:
            pieces.append(pd.DataFrame(columns=FINAL_COLS_A))
            log(f"  {label} sec={section} g1={g1_val} ns={out_ns} rows=0")
            continue
        sub["SOATO"] = sub["soato"].astype(str).str[:7]
        grouped = sub.groupby(["okpo", "SOATO"], as_index=False).agg({"g3": "sum"})
        result = grouped.rename(columns={"g3": "g1"})
        result["razdel"] = out_razdel
        result["ns"] = out_ns
        result["tur"] = tur
        out = pad_and_order_a(result)
        log(f"  {label} sec={section} g1={g1_val} ns={out_ns} rows={len(out):,}")
        pieces.append(out)
    return pieces


