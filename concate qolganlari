"""
Combined pipeline — runs all 6 source pipelines in memory and stacks the
results into a single Excel sheet.

Inputs:
  - 1-fx shakli_Yillik_1700.csv
  - 1- nnt shakli_Yillik_1700.csv
  - 1-notijorat shakli_Yillik_1700.csv
  - katalog for fx.xlsx
  - katalog for nnt.xlsx

Output:
  - combined_output.xlsx   (single sheet 'all_blocks', all rows stacked)

Pipelines (each produces the standard 25-column FINAL_COLS layout):

  Step1 family (ns 301-310, razdel comes from source section):
    1. fx          (section 26 -> 3, 10 blocks, tur='1-fx')
    2. nnt         (section  8 -> 3, 10 blocks, tur='1-nnt')
    3. notijorat   (section  7 -> 3, 10 blocks, tur='1-notijorat')

  Step4 family (ns 402-413, razdel = 4):
    4. fx          (section 26 -> 3, 11 blocks, tur='1-fx')
    5. nnt         (section  8 -> 3, 11 blocks, tur='1-nnt')
    6. notijorat   (section  7 -> 3, 11 blocks, tur='1-notijorat')

Run:  python combined_pipeline.py
"""

from pathlib import Path
import numpy as np
import pandas as pd


# ===========================================================================
# Config — file paths
# ===========================================================================
FX_CSV          = Path("1-fx shakli_Yillik_1700.csv")
NNT_CSV         = Path("1- nnt shakli_Yillik_1700.csv")
NOTIJORAT_CSV   = Path("1-notijorat shakli_Yillik_1700.csv")
KATALOG_FX_XLS  = Path("katalog for fx.xlsx")
KATALOG_NNT_XLS = Path("katalog for nnt.xlsx")

OUTPUT_FILE  = Path("mmmsndnd.xlsx")
OUTPUT_SHEET = "all_blocks"


